# Telegram Bot Tokens (one per language)
BOT_TOKEN_EN=your_token_here
BOT_TOKEN_UK=your_token_here
BOT_TOKEN_RU=your_token_here
BOT_TOKEN_AR=your_token_here
BOT_TOKEN_DE=your_token_here
BOT_TOKEN_ES=your_token_here
BOT_TOKEN_PT=your_token_here
BOT_TOKEN_FR=your_token_here

# Telegram Channel IDs (public channels per language)
CHANNEL_ID_EN=-100xxxxxxxxxx
CHANNEL_ID_UK=-100xxxxxxxxxx
CHANNEL_ID_RU=-100xxxxxxxxxx
CHANNEL_ID_AR=-100xxxxxxxxxx
CHANNEL_ID_DE=-100xxxxxxxxxx
CHANNEL_ID_ES=-100xxxxxxxxxx
CHANNEL_ID_PT=-100xxxxxxxxxx
CHANNEL_ID_FR=-100xxxxxxxxxx

# Claude API
ANTHROPIC_API_KEY=sk-ant-xxxxx

# CryptoBot
CRYPTOBOT_API_TOKEN=your_token_here

# HeyGen (video readings)
HEYGEN_API_KEY=your_key_here

# ElevenLabs (voice)
ELEVENLABS_API_KEY=your_key_here

# Database
DATABASE_DIR=./data

# ── Payments: Paddle (web Merchant of Record) ──
# Stripe is BANNED for tarot — see LLC Guide.
PADDLE_ENV=sandbox
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=

# Subscription price IDs (set after creating products in Paddle dashboard)
PADDLE_PRICE_INSIGHT_MONTHLY=
PADDLE_PRICE_INSIGHT_ANNUAL=
PADDLE_PRICE_PREMIUM_MONTHLY=
PADDLE_PRICE_PREMIUM_ANNUAL=
PADDLE_PRICE_VIP_MONTHLY=
PADDLE_PRICE_VIP_ANNUAL=

# Addon price IDs (one-time)
PADDLE_PRICE_ADDON_BIRTH_CHART=
PADDLE_PRICE_ADDON_COMPATIBILITY=
PADDLE_PRICE_ADDON_CELTIC_CROSS=
PADDLE_PRICE_ADDON_YEAR_AHEAD=
PADDLE_PRICE_ADDON_SOLAR_RETURN=
PADDLE_PRICE_ADDON_VIDEO_READING=

# ── Payments: Telegram Stars (in-bot) ──
